rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function adminDocExists() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isReservedAdminBootstrap(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.auth.token.email == 'admin@gmail.com' &&
        request.resource.data.role == 'admin';
    }

    function isAdmin() {
      return adminDocExists() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    match /users/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if signedIn() && (request.auth.uid == userId || isAdmin() || isReservedAdminBootstrap(userId));
      allow update: if signedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && request.resource.data.role == resource.data.role) ||
        isReservedAdminBootstrap(userId)
      );
      allow delete: if isAdmin();
    }

    match /complaints/{complaintId} {
      allow read: if signedIn();
      allow create: if signedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /ambulance_bookings/{bookingId} {
      allow read: if signedIn() && (resource.data.bookedByUserId == request.auth.uid || isAdmin());
      allow create: if signedIn() && request.resource.data.bookedByUserId == request.auth.uid;
      allow update: if signedIn() && (resource.data.bookedByUserId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }
  }
}